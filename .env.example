# Anthropic API key for the agent. Can also be configured later in the UI under
# Settings → connections, but setting it here is the simplest start.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — auth token signing secret. If unset, a strong secret is generated
# on first run and saved to {DATA_DIR}/secrets.json. Set it explicitly to manage
# it yourself or share it across instances. Generate one with: openssl rand -hex 32
# JWT_SECRET=

# Optional — dedicated 64-hex-char key for encrypting stored connection secrets.
# If unset: derived from JWT_SECRET when that is set, otherwise generated and
# saved to {DATA_DIR}/secrets.json. Set it to rotate it independently of the
# signing secret. Generate one with: openssl rand -hex 32
# ENCRYPTION_KEY=

# Optional — port to expose the web UI on (default: 80)
PORT=80

# Optional — override which Claude models are used
# DEFAULT_CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MODEL_LOW=claude-haiku-4-5-20251001
# CLAUDE_MODEL_MEDIUM=claude-sonnet-4-6
# CLAUDE_MODEL_HIGH=claude-opus-4-8

# Optional — set to "true" to allow new user registration
# ALLOW_REGISTRATION=true
