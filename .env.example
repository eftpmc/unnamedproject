# Required
JWT_SECRET=change-me-to-a-long-random-secret
ANTHROPIC_API_KEY=sk-ant-...

# Optional — port to expose the web UI on (default: 80)
PORT=80

# Optional — override which Claude models are used
# DEFAULT_CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MODEL_LOW=claude-haiku-4-5-20251001
# CLAUDE_MODEL_MEDIUM=claude-sonnet-4-6
# CLAUDE_MODEL_HIGH=claude-opus-4-8

# Optional — set to "true" to allow new user registration
# ALLOW_REGISTRATION=true
