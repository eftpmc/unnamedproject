{
  "manifest_version": 3,
  "name": "Unnamed Chrome Bridge",
  "version": "0.1.0",
  "description": "Connects the Unnamed local agent app to this Chrome profile.",
  "permissions": ["storage", "tabs", "scripting", "activeTab", "alarms", "debugger"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Unnamed Chrome Bridge"
  }
}
