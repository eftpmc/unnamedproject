PORT=3000
DATA_DIR=./data
# Optional — auth token signing secret. Auto-generated to {DATA_DIR}/secrets.json if unset. openssl rand -hex 32
# JWT_SECRET=
# Optional — encrypts stored connection secrets (64 hex). Derived from JWT_SECRET, else auto-generated. openssl rand -hex 32
# ENCRYPTION_KEY=
ALLOW_REGISTRATION=true
NODE_ENV=
# Google OAuth — required for Gmail integration. Create at console.cloud.google.com
# Enable Gmail API, create OAuth 2.0 credentials (Desktop app), add http://localhost:3000 as redirect URI.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APP_URL=http://localhost:3000
# System dependencies: claude CLI, codex CLI, graphify (pip install graphifyy)
